/**
 * Core Philosophy:
 * This ruleset enforces a strict, hierarchical ownership model centered around the 'Ristorante' (Restaurant) entity.
 * All data is scoped to a specific restaurant and is considered private to the restaurant's owner. The primary security
 * principle is "Authorization Independence," where authorization decisions for any document can be made by inspecting
 * that document alone, without needing to read related documents.
 *
 * Data Structure:
 * The data is organized under a single top-level collection: `/ristoranti`. Each document in this collection
 * represents a unique restaurant owned by a specific user (`proprietarioUid`). All other data entities, such as
 * tables (`tavoli`), reservations (`prenotazioni`), customers, and settings, are stored in dedicated subcollections
 * under their parent restaurant document (e.g., `/ristoranti/{ristoranteId}/tavoli/{tavoloId}`).
 *
 * Key Security Decisions:
 * - Strict Ownership: All access (read and write) to a restaurant's data and its subcollections is restricted to the
 *   authenticated user whose UID matches the `proprietarioUid` field on the documents.
 * - Public Listing for Restaurants: The top-level /ristoranti collection is publicly listable to allow users to
 *   browse restaurants on the landing page. Individual document reads are also public for booking pages.
 * - Subcollection Listing: Listing subcollections is allowed for authenticated owners, but client-side queries
 *   MUST enforce ownership by filtering on `proprietarioUid` to ensure users only see their own data.
 *
 * Denormalization for Authorization:
 * To ensure fast, secure, and independent authorization checks, the owner's user ID (`proprietarioUid`) is denormalized
 * (copied) from the parent `/ristoranti/{ristoranteId}` document into every single document within its subcollections.
 * This allows rules to verify ownership with a simple field check (`resource.data.proprietarioUid == request.auth.uid`)
 * for single-document operations, and enables query-based security for list operations.
 *
 * Structural Segregation:
 * The data model naturally segregates data by type into distinct collections (e.g., `tavoli`, `prenotazioni`). This
 * ensures that a single security rule definition applies uniformly to all documents within that collection, simplifying
 * logic and improving security.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Admin Access Functions
    // --------------------------------
    
    /**
     * Checks if the authenticated user is a super admin.
     */
    function isSuperAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    /**
     * Checks if admin has specific role.
     */
    function hasAdminRole(allowedRoles) {
      let adminDoc = getAfter(/databases/$(database)/documents/admins/$(request.auth.uid));
      return isSuperAdmin() && adminDoc.data.ruolo in allowedRoles;
    }

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is the owner of the document being created.
     * Compares the auth UID with the 'proprietarioUid' field in the incoming request data.
     */
    function isRequestingOwner(docData) {
      return isSignedIn() && docData.proprietarioUid == request.auth.uid;
    }

    /**
     * Checks if the currently authenticated user is the owner of an existing document.
     * Compares the auth UID with the 'proprietarioUid' field in the stored resource.
     */
    function isResourceOwner(doc) {
      return isSignedIn() && doc.data.proprietarioUid == request.auth.uid;
    }

    /**
     * Ensures a document exists before checking ownership.
     * Used for safe update and delete operations.
     */
    function isExistingResourceOwner(doc) {
      return doc != null && isResourceOwner(doc);
    }

    /**
     * Validates that the owner ID field cannot be changed during an update.
     */
    function isOwnerIdImmutable(doc) {
      return request.resource.data.proprietarioUid == doc.data.proprietarioUid;
    }

    /**
     * On create, validates that the document's internal `ristoranteId` field
     * matches the `ristoranteId` from the path, ensuring relational integrity.
     */
    function isParentRistoranteOnCreate(ristoranteId) {
      return request.resource.data.ristoranteId == ristoranteId;
    }

    /**
     * On update, ensures the document's `ristoranteId` field is immutable.
     */
    function isParentRistoranteImmutable(doc) {
      return request.resource.data.ristoranteId == doc.data.ristoranteId;
    }
    
    /**
     * Validates the structure of a public reservation creation request.
     */
    function isValidPublicPrenotazione() {
      let data = request.resource.data;
      return data.cliente.nome is string 
        && data.cliente.nome.size() > 0 
        && data.cliente.telefono is string 
        && data.cliente.telefono.size() > 0
        && data.numeroPersone > 0
        && data.stato == 'confermata';
    }


    // --------------------------------
    // Collection Rules
    // --------------------------------

    /**
     * @description Secures the top-level restaurant profiles.
     * @path /ristoranti/{ristoranteId}
     * @allow A restaurant owner (create, update, delete) their own document. Public users can read and list for booking.
     *        e.g., (update) User 'owner123' can write to `/ristoranti/resto-abc` if that doc contains `proprietarioUid: 'owner123'`.
     * @deny Any other user from modifying a restaurant they don't own.
     *       e.g., (get) User 'other456' is denied from updating `/ristoranti/resto-abc`.
     * @principle Enforces strict document ownership for writes, while allowing public reads for discovery.
     */
    match /ristoranti/{ristoranteId} {
      allow get: if true;
      allow list: if true;
      allow create: if isRequestingOwner(request.resource.data);
      allow update: if isExistingResourceOwner(resource) && isOwnerIdImmutable(resource);
      allow delete: if isExistingResourceOwner(resource);

      /**
       * @description Secures the restaurant's review flow configuration document.
       * @path /ristoranti/{ristoranteId}/reviewFlowConfiguration/{reviewFlowConfigId}
       * @allow The restaurant owner (create, get, update, delete) their own configuration. `list` is allowed for signed-in users but relies on client queries to filter.
       *        e.g., (get) User 'owner123' can read `/ristoranti/resto-abc/reviewFlowConfiguration/config` if the doc has `proprietarioUid: 'owner123'`.
       * @deny Another user from reading or writing the configuration.
       *       e.g., (update) User 'other456' cannot write to the document.
       * @principle Relies on the denormalized `proprietarioUid` field for fast, independent authorization on subcollection documents.
       */
      match /reviewFlowConfiguration/{reviewFlowConfigId} {
        allow get: if isResourceOwner(resource);
        allow list: if isSignedIn();
        allow create: if isRequestingOwner(request.resource.data) && isParentRistoranteOnCreate(ristoranteId);
        allow update: if isExistingResourceOwner(resource) && isOwnerIdImmutable(resource) && isParentRistoranteImmutable(resource);
        allow delete: if isExistingResourceOwner(resource);
      }

      /**
       * @description Secures the daily opening hours for a restaurant.
       * @path /ristoranti/{ristoranteId}/dailyOpeningHours/{dailyOpeningHoursId}
       * @allow The restaurant owner (create, get, update, delete) their opening hours. `list` is allowed for signed-in users but relies on client queries to filter.
       *        e.g., (create) User 'owner123' can create a new opening hour document if the new data includes `proprietarioUid: 'owner123'`.
       * @deny Another user from accessing the opening hours.
       * @principle Relies on the denormalized `proprietarioUid` field for fast, independent authorization on subcollection documents.
       */
      match /dailyOpeningHours/{dailyOpeningHoursId} {
        allow get: if true;
        allow list: if true;
        allow create: if isRequestingOwner(request.resource.data) && isParentRistoranteOnCreate(ristoranteId);
        allow update: if isExistingResourceOwner(resource) && isOwnerIdImmutable(resource) && isParentRistoranteImmutable(resource);
        allow delete: if isExistingResourceOwner(resource);
      }

      /**
       * @description Secures the restaurant's table definitions for the floor plan.
       * @path /ristoranti/{ristoranteId}/tavoli/{tavoloId}
       * @allow The restaurant owner (create, get, update, delete) their own tables. `list` is allowed for signed-in users but relies on client queries to filter. Public can read for booking.
       *        e.g., (update) User 'owner123' can update a table doc if it has `proprietarioUid: 'owner123'`.
       * @deny Another user from modifying table data.
       *       e.g., (delete) User 'other456' cannot delete a table document.
       * @principle Relies on the denormalized `proprietarioUid` field for fast, independent authorization on subcollection documents.
       */
      match /tavoli/{tavoloId} {
        allow get: if true;
        allow list: if true;
        allow create: if isRequestingOwner(request.resource.data) && isParentRistoranteOnCreate(ristoranteId);
        allow update: if isExistingResourceOwner(resource) && isOwnerIdImmutable(resource) && isParentRistoranteImmutable(resource);
        allow delete: if isExistingResourceOwner(resource);
      }

      /**
       * @description Secures customer data associated with a restaurant.
       * @path /ristoranti/{ristoranteId}/customers/{customerId}
       * @allow The restaurant owner (create, get, update, delete) their customer list. `list` is allowed for signed-in users but relies on client queries to filter.
       *        e.g., (get) User 'owner123' can read a customer doc if it has `proprietarioUid: 'owner123'`.
       * @deny Any other user from accessing customer information.
       *       e.g., (get) User 'other456' is denied access to any customer document.
       * @principle Relies on the denormalized `proprietarioUid` field for fast, independent authorization on subcollection documents.
       */
      match /customers/{customerId} {
        allow get: if isResourceOwner(resource);
        allow list: if isSignedIn();
        allow create: if isRequestingOwner(request.resource.data) && isParentRistoranteOnCreate(ristoranteId);
        allow update: if isExistingResourceOwner(resource) && isOwnerIdImmutable(resource) && isParentRistoranteImmutable(resource);
        allow delete: if isExistingResourceOwner(resource);
      }

      /**
       * @description Secures reservation data for a restaurant.
       * @path /ristoranti/{ristoranteId}/prenotazioni/{prenotazioneId}
       * @allow The restaurant owner can manage their reservations. Public users can create reservations and list them for availability checks.
       * @deny Another user from viewing or modifying reservations.
       * @principle Relies on the denormalized `proprietarioUid` field for fast, independent authorization on subcollection documents.
       */
      match /prenotazioni/{prenotazioneId} {
        allow get: if isResourceOwner(resource);
        allow list: if true;
        allow create: if isParentRistoranteOnCreate(ristoranteId) && isValidPublicPrenotazione();
        allow update: if isExistingResourceOwner(resource) && isOwnerIdImmutable(resource) && isParentRistoranteImmutable(resource);
        allow delete: if isExistingResourceOwner(resource);
      }

      /**
       * @description Secures the floor plan wall segments for a restaurant.
       * @path /ristoranti/{ristoranteId}/muri/{muroId}
       * @allow The restaurant owner (create, get, update, delete) the wall segments of their floor plan. Public can read for booking.
       *        e.g., (delete) User 'owner123' can delete a wall segment if the doc has `proprietarioUid: 'owner123'`.
       * @deny Any other user from altering the floor plan.
       *       e.g., (update) User 'other456' cannot update a wall segment document.
       * @principle Relies on the denormalized `proprietarioUid` field for fast, independent authorization on subcollection documents.
       */
      match /muri/{muroId} {
        allow get: if true;
        allow list: if true;
        allow create: if isRequestingOwner(request.resource.data) && isParentRistoranteOnCreate(ristoranteId);
        allow update: if isExistingResourceOwner(resource) && isOwnerIdImmutable(resource) && isParentRistoranteImmutable(resource);
        allow delete: if isExistingResourceOwner(resource);
      }

      /**
       * @description Secures the floor plan zone definitions for a restaurant.
       * @path /ristoranti/{ristoranteId}/zone/{zonaId}
       * @allow The restaurant owner (create, get, update, delete) the zones of their floor plan. Public can read for booking.
       *        e.g., (get) User 'owner123' can read a zone document if it contains `proprietarioUid: 'owner123'`.
       * @deny Any other user from accessing the floor plan zones.
       *       e.g., (get) User 'other456' is denied access.
       * @principle Relies on the denormalized `proprietarioUid` field for fast, independent authorization on subcollection documents.
       */
      match /zone/{zonaId} {
        allow get: if true;
        allow list: if true;
        allow create: if isRequestingOwner(request.resource.data) && isParentRistoranteOnCreate(ristoranteId);
        allow update: if isExistingResourceOwner(resource) && isOwnerIdImmutable(resource) && isParentRistoranteImmutable(resource);
        allow delete: if isExistingResourceOwner(resource);
      }
    }
    
    // --------------------------------
    // Admin Collection Rules
    // --------------------------------
    
    /**
     * @description Secures the admin users collection.
     * @path /admins/{adminId}
     * @allow Only existing super admins can manage other admins.
     */
    match /admins/{adminId} {
      allow get: if isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
    
    /**
     * @description Secures platform statistics.
     * @path /platform/stats
     * @allow Only super admins can read/update platform stats.
     */
    match /platform/stats {
      allow get: if isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
    
    // --------------------------------
    // Admin Override Rules for Restaurants
    // Admins can read/write all restaurant data
    // --------------------------------
    
    match /ristoranti/{ristoranteId} {
      allow get: if isSuperAdmin() || true;
      allow list: if isSuperAdmin() || true;
      allow create: if isSuperAdmin() || isRequestingOwner(request.resource.data);
      allow update: if isSuperAdmin() || (isExistingResourceOwner(resource) && isOwnerIdImmutable(resource));
      allow delete: if isSuperAdmin() || isExistingResourceOwner(resource);
      
      // Admin access to all subcollections
      match /{document=**} {
        allow get: if isSuperAdmin() || isResourceOwner(resource);
        allow list: if isSuperAdmin() || isSignedIn();
        allow create: if isSuperAdmin() || isRequestingOwner(request.resource.data);
        allow update: if isSuperAdmin() || (isExistingResourceOwner(resource) && isOwnerIdImmutable(resource));
        allow delete: if isSuperAdmin() || isExistingResourceOwner(resource);
      }
    }
  }
}
